# Backend-specific environment variables
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────
# Supabase PostgreSQL (use Transaction Pooler URL from Supabase dashboard)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-supabase-id.supabase.co:5432/postgres

# ─── JWT Authentication ──────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Application ─────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── CORS ────────────────────────────────────────────────────────
# JSON list of allowed frontend origins
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000"]

# ─── AI Configuration ────────────────────────────────────────────
# Max image file upload size in bytes (10MB)
MAX_IMAGE_SIZE_BYTES=10485760
# Max video file upload size in bytes (100MB)
MAX_VIDEO_SIZE_BYTES=104857600
# Emotion confidence threshold filter (ignore predictions below this %)
EMOTION_CONFIDENCE_THRESHOLD=30.0
